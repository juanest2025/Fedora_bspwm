#! /bin/sh
exec > /tmp/bspwmrc.log 2>&1

# ==========================================================
# 1. VISUAL STARTUP (Prioridad máxima para reducir pantalla negra)
# ==========================================================
xsetroot -cursor_name left_ptr

# Cerrar procesos antiguos
killall -q force_time_sync.sh dynamic_wallpaper.sh

# Wallpaper estático
feh --bg-fill "$HOME/wallpaper/casa.jpg" &

# ==========================================================
# 2. SISTEMA PRINCIPAL
# ==========================================================
# Start/Restart Hotkey Daemon
pgrep -x sxhkd > /dev/null && pkill -x sxhkd
SXHKD_SHELL=/bin/sh sxhkd -m 1 &

# Optimization: Increase keyboard repeat rate (Delay 300ms, Rate 50Hz)
xset r rate 300 50

# Apply keyboard layout
[ -f "$HOME/.config/dotfiles/keyboard.sh" ] && "$HOME/.config/dotfiles/keyboard.sh"

# Audio checks can take ~500ms to initialize. Se mandan a background para no pausar bspwm.
(
    if command -v pulseaudio >/dev/null 2>&1 && ! pgrep -x pipewire-pulse >/dev/null 2>&1; then
        pulseaudio --start >/dev/null 2>&1
    fi

    pactl set-source-mute @DEFAULT_SOURCE@ 0 >/dev/null 2>&1
    pactl set-source-volume @DEFAULT_SOURCE@ 100% >/dev/null 2>&1
) &

# ... (todo el resto de tu archivo queda exactamente igual)
