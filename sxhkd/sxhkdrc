# program launcher
alt + space
	"$HOME/.config/rofi/launcher.sh"
# program webs 
alt + m 
	"$HOME/.config/rofi/sitios/webs.sh"
# program sites 
alt + shift + i 
	"$HOME/.config/rofi/sitios/sites.sh"
